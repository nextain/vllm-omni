{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"verbatimModuleSyntax": true,
		"strict": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*.ts"]
}
